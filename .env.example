# Claude API key (required for tailoring). Get one at https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: default model (claude-sonnet-4-20250514 or claude-opus-4-5)
RESUMEAI_DEFAULT_MODEL=claude-sonnet-4-20250514

# Optional: max characters sent to API (resume / job description)
RESUMEAI_MAX_RESUME_CHARS=12000
RESUMEAI_MAX_JD_CHARS=5000

# Optional: server
RESUMEAI_HOST=0.0.0.0
RESUMEAI_PORT=5001
RESUMEAI_DEBUG=0
